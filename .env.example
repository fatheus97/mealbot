# Choose which LLM provider to use: "gemini" or "openai"
LLM_PROVIDER=gemini

# Get your keys at https://aistudio.google.com/ and https://platform.openai.com/

# Gemini API (free tier from Google AI Studio)
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (optional, for later)
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# Postgres credentials (used by docker-compose.yml)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mealbot

DATABASE_URL=postgresql+psycopg://user:password@db:5432/mealbot
DB_ECHO=False

# Optional local mock mode (set to "true" to bypass real API)
LLM_MOCK=false

# Optional RAG usage
USE_RAG=false

# LLM consistency testing
RUN_LLM_TESTS=false

# REQUIRED: Generate a strong random key (e.g. `openssl rand -hex 32`)
SECRET_KEY=CHANGE_ME

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174